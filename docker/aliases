alias d='docker'

alias dc='docker compose'
alias dcd='docker compose down'
alias dcu='docker compose up'
alias dcud='docker compose up -d'

alias dl='docker logs --tail 200'

alias dps='docker ps'

alias dprune='docker system prune -af --volumes'

alias dvl='docker volume ls'
alias dvi='docker volume inspect'
alias dvr='docker volume rm'

function dockerUpdatePull() {
  local d count=0 docker_root="${DOCKER_ROOT:-$HOME/dotfiles/docker}"

  if [[ ! -d "$docker_root" ]]; then
    echo "No such directory: $docker_root"
    return 1
  fi

  _dup_has_compose() {
    [[ -f "$1/docker-compose.yml" || -f "$1/docker-compose.yaml" || -f "$1/compose.yml" || -f "$1/compose.yaml" ]]
  }

  _dup_update() {
    echo "→ $1"
    (cd "$1" && sudo docker compose pull && sudo docker compose up -d) || return 1
  }

  if _dup_has_compose "$docker_root"; then
    _dup_update "$docker_root" || return 1
    count=$((count + 1))
  fi

  while IFS= read -r d; do
    _dup_has_compose "$d" || continue
    _dup_update "$d" || return 1
    count=$((count + 1))
  done < <(find "$docker_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)

  if ((count == 0)); then
    echo "No docker compose projects found in $docker_root"
    return 1
  fi
  echo "Updated $count project(s)"
}
alias dup=dockerUpdatePull